{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "mkdocs",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "mkdocs", "serve", "-a", "127.0.0.1:8765"],
      "port": 8765
    },
    {
      "name": "view-forecasts",
      "runtimeExecutable": "uv",
